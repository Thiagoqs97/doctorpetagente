# ============================================
# VET-AGENT — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# ---- Google Gemini ----
GEMINI_API_KEY=

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---- Evolution API ----
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ---- WhatsApp — grupo para relatórios ----
# ID do grupo no formato: 5511999999999-1234567890@g.us
REPORT_GROUP_ID=

# ---- Clínica ----
CLINIC_NAME=Clínica Veterinária
CLINIC_PHONE=5511999999999
CLINIC_ADDRESS=Av. Principal, 100 - Centro
CLINIC_HOURS=Seg a Sex: 08:00 as 18:00 / Sab: 08:00 as 12:00

# ---- Relatório diário ----
# Formato cron: min hora dia mês dia-semana
REPORT_CRON=0 8 * * *
REPORT_TIMEZONE=America/Sao_Paulo

# ---- Servidor ----
PORT=3000

# ---- Admin (escalonamento humano) ----
# Telefone do responsável no formato: 5511999999999
ADMIN_PHONE=
